{"markdown":{"containsRefs":false,"markdown":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"Data Science Portfolio - Reproducible research, ecological modelling, data visualisation\">\n    <meta name=\"author\" content=\"[Nama Anda]\">\n    <title>Data Science Portfolio | [Nama Anda]</title>\n    <link rel=\"stylesheet\" href=\"css/style.css\">\n    <link rel=\"stylesheet\" href=\"css/responsive.css\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n</head>\n<body>\n    <!-- Dark Mode Toggle -->\n    <div class=\"dark-mode-toggle\">\n        <i class=\"fas fa-moon\"></i>\n    </div>\n\n    <!-- Header / Navigation -->\n    <header>\n        <nav>\n            <div class=\"logo\">\n                <a href=\"index.html\">🌿 [Nama Anda] | Data & Ecology</a>\n            </div>\n            <ul class=\"nav-links\">\n                <li><a href=\"index.html\" class=\"active\">Projects</a></li>\n                <li><a href=\"blog.html\">Blog</a></li>\n                <li><a href=\"about.html\">About</a></li>\n                <li><a href=\"contact.html\">Contact</a></li>\n            </ul>\n            <div class=\"burger\">\n                <div class=\"line1\"></div>\n                <div class=\"line2\"></div>\n                <div class=\"line3\"></div>\n            </div>\n        </nav>\n    </header>\n\n    <main>\n        <!-- Hero Section -->\n        <section class=\"hero\">\n            <div class=\"hero-content\">\n                <h1>Reproducible <span class=\"highlight\">Data Science</span></h1>\n                <p>Transparency • Robust Methods • Open Science</p>\n                <div class=\"hero-buttons\">\n                    <a href=\"#projects\" class=\"btn-primary\">Explore Projects →</a>\n                    <a href=\"assets/docs/cv.pdf\" class=\"btn-secondary\" target=\"_blank\">Download CV</a>\n                </div>\n                <div class=\"hero-stats\">\n                    <div class=\"stat\">\n                        <span class=\"stat-number\">10+</span>\n                        <span class=\"stat-label\">Research Projects</span>\n                    </div>\n                    <div class=\"stat\">\n                        <span class=\"stat-number\">100%</span>\n                        <span class=\"stat-label\">Reproducible</span>\n                    </div>\n                    <div class=\"stat\">\n                        <span class=\"stat-number\">Open</span>\n                        <span class=\"stat-label\">Source Code</span>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- Search Section -->\n        <section class=\"search-section\">\n            <div class=\"container\">\n                <div class=\"search-wrapper\">\n                    <i class=\"fas fa-search\"></i>\n                    <input type=\"text\" id=\"searchInput\" placeholder=\"Search projects by title, method, or topic...\">\n                </div>\n            </div>\n        </section>\n\n        <!-- Filters -->\n        <section class=\"filters\">\n            <div class=\"container\">\n                <div class=\"filter-group\">\n                    <button class=\"filter-btn active\" data-filter=\"all\">All Projects</button>\n                    <button class=\"filter-btn\" data-filter=\"ecology\">🌿 Ecology & Modelling</button>\n                    <button class=\"filter-btn\" data-filter=\"visualisation\">📊 Data Visualisation</button>\n                    <button class=\"filter-btn\" data-filter=\"r-project\">📈 R Project</button>\n                    <button class=\"filter-btn\" data-filter=\"python\">🐍 Python</button>\n                    <button class=\"filter-btn\" data-filter=\"dashboard\">📱 Dashboard</button>\n                </div>\n            </div>\n        </section>\n\n        <!-- Projects Grid -->\n        <section id=\"projects\" class=\"projects-section\">\n            <div class=\"container\">\n                <div class=\"section-header\">\n                    <h2>Featured Research Projects</h2>\n                    <p>Inspired by ALA Labs — each project includes full code, data sources, and transparent methods</p>\n                </div>\n                <div class=\"projects-grid\" id=\"projectsGrid\">\n                    <!-- Project 1: Biodiversity Dashboard -->\n                    <div class=\"project-card\" data-category=\"ecology r-project dashboard\" data-title=\"biodiversity trends australia\">\n                        <div class=\"card-badge\">Featured</div>\n                        <div class=\"card-image\">\n                            <img src=\"assets/images/project-thumb-1.jpg\" alt=\"Biodiversity Dashboard\">\n                            <div class=\"card-overlay\">\n                                <a href=\"projects/biodiversity-dashboard/\" class=\"btn-small\">Live Demo →</a>\n                            </div>\n                        </div>\n                        <div class=\"card-content\">\n                            <div class=\"card-meta\">\n                                <span class=\"date\">2024</span>\n                                <span class=\"tech\">R • flexdashboard • ALA4R</span>\n                            </div>\n                            <h3>Biodiversity Trends in Australia</h3>\n                            <p>Interactive dashboard visualising 50,000+ occurrence records from Atlas of Living Australia. Includes temporal trends, species richness maps, and data quality filters.</p>\n                            <div class=\"card-links\">\n                                <a href=\"projects/biodiversity-dashboard/\" class=\"link\">View Project →</a>\n                                <a href=\"https://github.com/[username]/biodiversity-dashboard\" class=\"link-icon\"><i class=\"fab fa-github\"></i> Code</a>\n                                <a href=\"projects/biodiversity-dashboard/methods.pdf\" class=\"link-icon\"><i class=\"fas fa-file-pdf\"></i> Methods</a>\n                            </div>\n                            <div class=\"tags\">\n                                <span>Occurrence data</span>\n                                <span>Spatial analysis</span>\n                                <span>Time series</span>\n                                <span>Data cleaning</span>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- Project 2: Species Distribution Modelling -->\n                    <div class=\"project-card\" data-category=\"ecology python\" data-title=\"maxent species distribution modelling\">\n                        <div class=\"card-image\">\n                            <img src=\"assets/images/project-thumb-2.jpg\" alt=\"Species Distribution Model\">\n                            <div class=\"card-overlay\">\n                                <a href=\"projects/species-modelling/\" class=\"btn-small\">View Report →</a>\n                            </div>\n                        </div>\n                        <div class=\"card-content\">\n                            <div class=\"card-meta\">\n                                <span class=\"date\">2024</span>\n                                <span class=\"tech\">Python • MaxEnt • GeoPandas</span>\n                            </div>\n                            <h3>MaxEnt Species Distribution Modelling</h3>\n                            <p>Presence-only modelling for 5 endangered species. Includes uncertainty quantification, cross-validation, and bias correction for citizen science data.</p>\n                            <div class=\"card-links\">\n                                <a href=\"projects/species-modelling/\" class=\"link\">View Project →</a>\n                                <a href=\"https://github.com/[username]/species-modelling\" class=\"link-icon\"><i class=\"fab fa-github\"></i> Code</a>\n                                <a href=\"projects/species-modelling/methods.pdf\" class=\"link-icon\"><i class=\"fas fa-file-pdf\"></i> Methods</a>\n                            </div>\n                            <div class=\"tags\">\n                                <span>MaxEnt</span>\n                                <span>SDM</span>\n                                <span>Uncertainty</span>\n                                <span>BIOCLIM</span>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- Project 3: GBIF Data Analysis -->\n                    <div class=\"project-card\" data-category=\"r-project visualisation\" data-title=\"gbif data cleaning visualization\">\n                        <div class=\"card-image\">\n                            <img src=\"assets/images/project-thumb-3.jpg\" alt=\"GBIF Analysis\">\n                            <div class=\"card-overlay\">\n                                <a href=\"projects/gbif-analysis/\" class=\"btn-small\">View Analysis →</a>\n                            </div>\n                        </div>\n                        <div class=\"card-content\">\n                            <div class=\"card-meta\">\n                                <span class=\"date\">2023</span>\n                                <span class=\"tech\">R • rgbif • ggplot2 • sf</span>\n                            </div>\n                            <h3>GBIF Data Cleaning & Visualisation</h3>\n                            <p>Replicable workflow for downloading, cleaning, and visualising 100,000+ occurrence records. Includes coordinate validation, outlier detection, and publication-ready maps.</p>\n                            <div class=\"card-links\">\n                                <a href=\"projects/gbif-analysis/\" class=\"link\">View Project →</a>\n                                <a href=\"https://github.com/[username]/gbif-analysis\" class=\"link-icon\"><i class=\"fab fa-github\"></i> Code</a>\n                                <a href=\"projects/gbif-analysis/workflow.md\" class=\"link-icon\"><i class=\"fas fa-file-alt\"></i> Workflow</a>\n                            </div>\n                            <div class=\"tags\">\n                                <span>rgbif</span>\n                                <span>Data validation</span>\n                                <span>ggplot2</span>\n                                <span>Open data</span>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- Project 4: Shiny App for Conservation Planning -->\n                    <div class=\"project-card\" data-category=\"dashboard r-project ecology\" data-title=\"conservation planning shiny app\">\n                        <div class=\"card-image\">\n                            <img src=\"assets/images/project-thumb-4.jpg\" alt=\"Conservation Planning\">\n                            <div class=\"card-overlay\">\n                                <a href=\"projects/conservation-app/\" class=\"btn-small\">Launch App →</a>\n                            </div>\n                        </div>\n                        <div class=\"card-content\">\n                            <div class=\"card-meta\">\n                                <span class=\"date\">2024</span>\n                                <span class=\"tech\">R Shiny • leaflet • prioritizr</span>\n                            </div>\n                            <h3>Conservation Prioritisation Tool</h3>\n                            <p>Interactive Shiny app for identifying priority conservation areas based on species richness, threat status, and land cost. Includes Marxan connectivity.</p>\n                            <div class=\"card-links\">\n                                <a href=\"projects/conservation-app/\" class=\"link\">View Project →</a>\n                                <a href=\"https://github.com/[username]/conservation-app\" class=\"link-icon\"><i class=\"fab fa-github\"></i> Code</a>\n                                <a href=\"projects/conservation-app/methods.pdf\" class=\"link-icon\"><i class=\"fas fa-file-pdf\"></i> Methods</a>\n                            </div>\n                            <div class=\"tags\">\n                                <span>Shiny</span>\n                                <span>Conservation</span>\n                                <span>Prioritizr</span>\n                                <span>Interactive</span>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- Project 5: Climate Data Analysis -->\n                    <div class=\"project-card\" data-category=\"python visualisation\" data-title=\"climate change impact analysis\">\n                        <div class=\"card-image\">\n                            <img src=\"assets/images/project-thumb-5.jpg\" alt=\"Climate Analysis\">\n                            <div class=\"card-overlay\">\n                                <a href=\"projects/climate-analysis/\" class=\"btn-small\">View Analysis →</a>\n                            </div>\n                        </div>\n                        <div class=\"card-content\">\n                            <div class=\"card-meta\">\n                                <span class=\"date\">2023</span>\n                                <span class=\"tech\">Python • xarray • matplotlib</span>\n                            </div>\n                            <h3>Climate Change Impact on Biodiversity</h3>\n                            <p>Analysis of 50 years of climate data and its correlation with species distribution shifts. Includes anomaly detection and future projections under RCP scenarios.</p>\n                            <div class=\"card-links\">\n                                <a href=\"projects/climate-analysis/\" class=\"link\">View Project →</a>\n                                <a href=\"https://github.com/[username]/climate-analysis\" class=\"link-icon\"><i class=\"fab fa-github\"></i> Code</a>\n                            </div>\n                            <div class=\"tags\">\n                                <span>Climate data</span>\n                                <span>Time series</span>\n                                <span>NetCDF</span>\n                                <span>CMIP6</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Load More Button -->\n                <div class=\"load-more\">\n                    <button id=\"loadMoreBtn\" class=\"btn-outline\">Load More Projects</button>\n                </div>\n            </div>\n        </section>\n\n        <!-- Values Section (ALA Labs Style) -->\n        <section class=\"values-section\">\n            <div class=\"container\">\n                <h2>Scientific Transparency & Robust Methods</h2>\n                <p class=\"values-subtitle\">Core principles adopted from ALA Labs</p>\n                <div class=\"values-grid\">\n                    <div class=\"value-card\">\n                        <div class=\"value-icon\">\n                            <img src=\"assets/images/icon-reproducible.svg\" alt=\"Reproducible\">\n                        </div>\n                        <h3>Fully Reproducible</h3>\n                        <p>Every analysis includes complete code, session info, and data sources. One-click replication from GitHub.</p>\n                        <div class=\"value-badge\">✓ Verified 2024</div>\n                    </div>\n                    <div class=\"value-card\">\n                        <div class=\"value-icon\">\n                            <img src=\"assets/images/icon-transparent.svg\" alt=\"Transparent\">\n                        </div>\n                        <h3>Methods Disclosed</h3>\n                        <p>Strengths AND limitations clearly stated. No hidden assumptions or p-hacking.</p>\n                        <div class=\"value-badge\">✓ Peer-reviewed workflow</div>\n                    </div>\n                    <div class=\"value-card\">\n                        <div class=\"value-icon\">\n                            <img src=\"assets/images/icon-robust.svg\" alt=\"Robust\">\n                        </div>\n                        <h3>Robust & Validated</h3>\n                        <p>Cross-validation, sensitivity analysis, and uncertainty quantification for all models.</p>\n                        <div class=\"value-badge\">✓ Statistical rigor</div>\n                    </div>\n                    <div class=\"value-card\">\n                        <div class=\"value-icon\">\n                            <i class=\"fas fa-handshake\"></i>\n                        </div>\n                        <h3>Ethical Data Use</h3>\n                        <p>Acknowledging Traditional Owners, data custodians, and ethical collection protocols.</p>\n                        <div class=\"value-badge\">✓ Indigenous data sovereignty</div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- Newsletter / Updates Section -->\n        <section class=\"newsletter\">\n            <div class=\"container\">\n                <div class=\"newsletter-content\">\n                    <h3>Stay Updated on New Projects</h3>\n                    <p>Get notified when I publish new research or methods tutorials</p>\n                    <form id=\"newsletterForm\" class=\"newsletter-form\">\n                        <input type=\"email\" placeholder=\"Your email address\" required>\n                        <button type=\"submit\">Subscribe →</button>\n                    </form>\n                    <p class=\"newsletter-note\">No spam. Unsubscribe anytime.</p>\n                </div>\n            </div>\n        </section>\n    </main>\n\n    <footer>\n        <div class=\"footer-content\">\n            <div class=\"footer-section\">\n                <h4>🌿 [Nama Anda]</h4>\n                <p>Data Scientist & Ecologist</p>\n                <p>Reproducible research for biodiversity conservation</p>\n            </div>\n            <div class=\"footer-section\">\n                <h4>Quick Links</h4>\n                <ul>\n                    <li><a href=\"index.html\">Projects</a></li>\n                    <li><a href=\"blog.html\">Blog</a></li>\n                    <li><a href=\"about.html\">About</a></li>\n                    <li><a href=\"contact.html\">Contact</a></li>\n                </ul>\n            </div>\n            <div class=\"footer-section\">\n                <h4>Follow</h4>\n                <div class=\"social-links\">\n                    <a href=\"https://github.com/[username]\" target=\"_blank\"><i class=\"fab fa-github\"></i></a>\n                    <a href=\"https://linkedin.com/in/[username]\" target=\"_blank\"><i class=\"fab fa-linkedin\"></i></a>\n                    <a href=\"https://twitter.com/[username]\" target=\"_blank\"><i class=\"fab fa-twitter\"></i></a>\n                    <a href=\"https://orcid.org/0000-0000-0000-0000\" target=\"_blank\"><i class=\"fab fa-orcid\"></i></a>\n                </div>\n            </div>\n            <div class=\"footer-section\">\n                <h4>Cite This Portfolio</h4>\n                <code>[Nama Anda]. (2024). Data Science Portfolio. GitHub Pages.</code>\n                <a href=\"#\" class=\"btn-copy\">Copy BibTeX</a>\n            </div>\n        </div>\n        <div class=\"footer-bottom\">\n            <p>© 2024 [Nama Anda] — Built with HTML/CSS/JS | Hosted on GitHub Pages</p>\n            <p>Acknowledgment: Inspired by <a href=\"https://labs.ala.org.au/\" target=\"_blank\">ALA Labs</a> and their commitment to open science</p>\n        </div>\n    </footer>\n\n    <script src=\"js/main.js\"></script>\n    <script src=\"js/search.js\"></script>\n    <script src=\"js/dark-mode.js\"></script>\n</body>\n</html>","srcMarkdownNoYaml":""},"formats":{"html":{"identifier":{"display-name":"HTML","target-format":"html","base-format":"html"},"execute":{"fig-width":7,"fig-height":5,"fig-format":"retina","fig-dpi":96,"df-print":"default","error":false,"eval":true,"cache":null,"freeze":false,"echo":true,"output":true,"warning":true,"include":true,"keep-md":false,"keep-ipynb":false,"ipynb":null,"enabled":null,"daemon":null,"daemon-restart":false,"debug":false,"ipynb-filters":[],"ipynb-shell-interactivity":null,"plotly-connected":true,"engine":"markdown"},"render":{"keep-tex":false,"keep-typ":false,"keep-source":false,"keep-hidden":false,"prefer-html":false,"output-divs":true,"output-ext":"html","fig-align":"default","fig-pos":null,"fig-env":null,"code-fold":true,"code-overflow":"scroll","code-link":false,"code-line-numbers":false,"code-tools":false,"tbl-colwidths":"auto","merge-includes":true,"inline-includes":false,"preserve-yaml":false,"latex-auto-mk":true,"latex-auto-install":true,"latex-clean":true,"latex-min-runs":1,"latex-max-runs":10,"latex-makeindex":"makeindex","latex-makeindex-opts":[],"latex-tlmgr-opts":[],"latex-input-paths":[],"latex-output-dir":null,"link-external-icon":false,"link-external-newwindow":false,"self-contained-math":false,"format-resources":[],"notebook-links":true},"pandoc":{"standalone":true,"wrap":"none","default-image-extension":"png","to":"html","toc":true,"output-file":"02_JPR_Portfolio_main.html"},"language":{"toc-title-document":"Table of contents","toc-title-website":"On this page","related-formats-title":"Other Formats","related-notebooks-title":"Notebooks","source-notebooks-prefix":"Source","other-links-title":"Other Links","code-links-title":"Code Links","la